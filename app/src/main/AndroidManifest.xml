<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Adahi">

        <!-- Main Activity - Entry point -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Animal List Activity - Display list of available animals -->
        <activity
            android:name=".activities.AnimalListActivity"
            android:exported="false"
            android:label="@string/animal_list_title" />

        <!-- Animal Detail Activity - Show animal details and reservation actions -->
        <activity
            android:name=".activities.AnimalDetailActivity"
            android:exported="false"
            android:label="@string/animal_detail_title" />

        <!-- Order Form Activity - Collect customer details and place order -->
        <activity
            android:name=".activities.OrderFormActivity"
            android:exported="false"
            android:label="@string/order_form_title" />

        <!-- Order Confirmation Activity - Display order summary -->
        <activity
            android:name=".activities.OrderConfirmationActivity"
            android:exported="false"
            android:label="@string/order_confirmation_title" />

        <activity
            android:name=".activities.OrderTrackingActivity"
            android:exported="false"
            android:label="@string/order_tracking_title" />

    </application>

</manifest>