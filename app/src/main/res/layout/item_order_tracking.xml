<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@color/adahi_surface_container_lowest"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/adahi_outline_variant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/animalNameTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="اسم الأضحية"
            android:textColor="@color/adahi_on_surface"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/orderPlaceTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="الولاية: ---"
            android:textColor="@color/adahi_on_surface_variant"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/orderPriceTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="end"
            android:text="0 د.ج"
            android:textColor="@color/adahi_primary"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
