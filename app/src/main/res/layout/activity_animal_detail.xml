<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/adahi_background"
    android:layoutDirection="rtl">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/detailActionBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="260dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/adahi_surface_container"
                    android:contentDescription="@string/animal_card_image_description"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_gallery" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="16dp"
                    app:cardBackgroundColor="@color/adahi_primary"
                    app:cardCornerRadius="999dp"
                    app:cardElevation="0dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="8dp"
                        android:text="@string/verified_health_badge"
                        android:textColor="@color/adahi_on_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="فحص بيطري معتمد" />
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp">

                <TextView
                    android:id="@+id/animalDetailName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/adahi_on_surface"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    tools:text="خروف العيد - الفئة الممتازة" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layoutDirection="rtl">

                    <TextView
                        android:id="@+id/animalDetailType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/adahi_on_surface_variant"
                        android:textSize="13sp"
                        tools:text="الصنف: كبش" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="•"
                        android:textColor="@color/adahi_on_surface_variant" />

                    <TextView
                        android:id="@+id/animalDetailWeight"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/adahi_on_surface_variant"
                        android:textSize="13sp"
                        tools:text="الوزن: 58 كغ" />
                </LinearLayout>

                <TextView
                    android:id="@+id/animalDetailPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/adahi_primary"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    tools:text="78,000 د.ج" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/adahi_surface_container_lowest"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="المواصفات"
                        android:textColor="@color/adahi_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/animalBreedText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="@color/adahi_on_surface_variant"
                        android:textSize="14sp"
                        tools:text="السلالة: أولاد جلال" />

                    <TextView
                        android:id="@+id/animalAgeText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/adahi_on_surface_variant"
                        android:textSize="14sp"
                        tools:text="العمر: 18 شهر" />

                    <TextView
                        android:id="@+id/animalGenderText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/adahi_on_surface_variant"
                        android:textSize="14sp"
                        tools:text="الجنس: ذكر" />

                    <TextView
                        android:id="@+id/animalHealthStatusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/adahi_on_surface_variant"
                        android:textSize="14sp"
                        tools:text="الحالة الصحية: مفحوص بيطرياً" />

                    <TextView
                        android:id="@+id/animalSalesPointText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/adahi_on_surface_variant"
                        android:textSize="14sp"
                        tools:text="نقطة البيع: سوق بئر توتة" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/adahi_surface_container_lowest"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="الحالة الصحية"
                        android:textColor="@color/adahi_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/animalDetailDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="@color/adahi_on_surface_variant"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"
                        tools:text="فحص بيطري معتمد، تغذية طبيعية 100%، وخالية من أي عيوب شرعية." />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/adahi_surface_container_low"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="اختر الوزن المفضل"
                        android:textColor="@color/adahi_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:columnCount="2"
                        android:useDefaultMargins="true">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            app:cardBackgroundColor="@color/adahi_surface_container_lowest"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:padding="16dp"
                                android:text="45 - 50 كغ"
                                android:textColor="@color/adahi_on_surface"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            app:cardBackgroundColor="@color/adahi_primary_fixed"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:padding="16dp"
                                android:text="55 - 60 كغ"
                                android:textColor="@color/adahi_on_primary_fixed_variant"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </com.google.android.material.card.MaterialCardView>
                    </GridLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/detailActionBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/adahi_surface_container_lowest"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layoutDirection="rtl">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="العربون 3,000 د.ج"
                android:textColor="@color/adahi_on_surface_variant"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="السعر النهائي يحدد بعد الوزن"
                android:textColor="@color/adahi_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <Button
            android:id="@+id/directPurchaseButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/adahi_primary"
            android:text="شراء مباشر"
            android:textColor="@color/adahi_on_primary" />

        <Button
            android:id="@+id/reviewReservationButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/adahi_surface_container_high"
            android:text="حجز للمعاينة"
            android:textColor="@color/adahi_on_surface" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
